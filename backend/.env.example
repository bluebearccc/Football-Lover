# Server
NODE_ENV=development
PORT=4000

# PostgreSQL connection for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/football_lover?schema=public"

# Auth
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
RESET_TOKEN_TTL_MINUTES="60"
FRONTEND_URL="http://localhost:5173"

# Seed admin (UC E1)
ADMIN_EMAIL="admin@football-lover.local"
ADMIN_PASSWORD="Admin12345"
ADMIN_DISPLAY_NAME="Administrator"

# Integrations
API_FOOTBALL_KEY=""
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
CHATBOT_PROXY_URL="http://localhost:8787"
CHATBOT_PROXY_SECRET=""
CHATBOT_SAVE_CONVERSATIONS="true"
# Email provider (password reset)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="no-reply@football-lover.local"
